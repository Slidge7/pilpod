{
  "manifest_version": 3,
  "name": "PilPod Companion",
  "version": "1.0.0",
  "description": "Bridge between browser media tabs and the PilPod desktop app.",
  "permissions": ["storage", "tabs", "scripting"],
  "host_permissions": ["http://127.0.0.1:17399/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
