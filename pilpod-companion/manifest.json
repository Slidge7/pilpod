{
  "manifest_version": 3,
  "name": "PilPod Companion",
  "version": "1.3.0",
  "description": "Bridge between browser media tabs and the PilPod desktop app. Tracks all tabs with media state detection and full tab lifecycle management.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage", "tabs", "windows"],
  "host_permissions": ["http://127.0.0.1:17399/*", "http://127.0.0.1:17400/*"],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["dist/content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
