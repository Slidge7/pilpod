{
  "manifest_version": 3,
  "name": "PilPod Companion",
  "version": "2.0.0",
  "description": "Bridge between browser media tabs and the PilPod desktop app. Tracks tab states and syncs media controls securely via localhost.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "tabs",
    "windows",
    "alarms",
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "http://127.0.0.1:17399/*",
    "ws://127.0.0.1:17400/*"
  ],
  "optional_host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "src/ui/standalone.html",
    "default_icon": "icons/icon48.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src 'self' http://127.0.0.1:* ws://127.0.0.1:*;"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*",
        "*://youtube.com/*",
        "*://*.youtu.be/*",
        "*://youtu.be/*",
        "*://*.music.youtube.com/*",
        "*://music.youtube.com/*",
        "*://*.open.spotify.com/*",
        "*://open.spotify.com/*",
        "*://*.vimeo.com/*",
        "*://vimeo.com/*",
        "*://*.twitch.tv/*",
        "*://twitch.tv/*",
        "*://*.clips.twitch.tv/*",
        "*://clips.twitch.tv/*",
        "*://*.netflix.com/*",
        "*://netflix.com/*",
        "*://*.primevideo.com/*",
        "*://primevideo.com/*",
        "*://*.amazon.com/*",
        "*://amazon.com/*",
        "*://*.disneyplus.com/*",
        "*://disneyplus.com/*",
        "*://*.hulu.com/*",
        "*://hulu.com/*",
        "*://*.max.com/*",
        "*://max.com/*",
        "*://*.play.max.com/*",
        "*://play.max.com/*",
        "*://*.tv.apple.com/*",
        "*://tv.apple.com/*",
        "*://*.plex.tv/*",
        "*://plex.tv/*",
        "*://*.crunchyroll.com/*",
        "*://crunchyroll.com/*",
        "*://*.dailymotion.com/*",
        "*://dailymotion.com/*",
        "*://*.facebook.com/*",
        "*://facebook.com/*",
        "*://*.instagram.com/*",
        "*://instagram.com/*",
        "*://*.x.com/*",
        "*://x.com/*",
        "*://*.twitter.com/*",
        "*://twitter.com/*",
        "*://*.vk.com/*",
        "*://vk.com/*",
        "*://*.bilibili.com/*",
        "*://bilibili.com/*",
        "*://*.odysee.com/*",
        "*://odysee.com/*",
        "*://*.bbc.co.uk/*",
        "*://bbc.co.uk/*",
        "*://*.podcasts.apple.com/*",
        "*://podcasts.apple.com/*",
        "*://*.podcast.spotify.com/*",
        "*://podcast.spotify.com/*",
        "*://*.deezer.com/*",
        "*://deezer.com/*",
        "*://*.bandcamp.com/*",
        "*://bandcamp.com/*",
        "*://*.mixcloud.com/*",
        "*://mixcloud.com/*",
        "*://*.audiomack.com/*",
        "*://audiomack.com/*",
        "*://*.player.fm/*",
        "*://player.fm/*",
        "*://*.archive.org/*",
        "*://archive.org/*",
        "*://*.ted.com/*",
        "*://ted.com/*",
        "*://*.coursera.org/*",
        "*://coursera.org/*",
        "*://*.udemy.com/*",
        "*://udemy.com/*",
        "*://*.linkedin.com/*",
        "*://linkedin.com/*",
        "*://*.skillshare.com/*",
        "*://skillshare.com/*",
        "*://*.loom.com/*",
        "*://loom.com/*",
        "*://*.wistia.com/*",
        "*://wistia.com/*",
        "*://*.soundcloud.com/*",
        "*://soundcloud.com/*",
        "*://*.kick.com/*",
        "*://kick.com/*",
        "*://*.rumble.com/*",
        "*://rumble.com/*",
        "*://*.tiktok.com/*",
        "*://tiktok.com/*",
        "*://*.youtube-nocookie.com/*",
        "*://youtube-nocookie.com/*",
        "*://*.player.twitch.tv/*",
        "*://player.twitch.tv/*",
        "*://*.listen.tidal.com/*",
        "*://listen.tidal.com/*",
        "*://*.iqiyi.com/*",
        "*://iqiyi.com/*",
        "*://*.shahid.mbc.net/*",
        "*://shahid.mbc.net/*",
        "*://*.dazn.com/*",
        "*://dazn.com/*",
        "*://*.espn.com/*",
        "*://espn.com/*",
        "*://*.plus.rtl.de/*",
        "*://plus.rtl.de/*",
        "*://*.joyn.de/*",
        "*://joyn.de/*",
        "*://*.globoplay.globo.com/*",
        "*://globoplay.globo.com/*",
        "*://*.hotstar.com/*",
        "*://hotstar.com/*",
        "*://*.spotify.com/*",
        "*://spotify.com/*"
      ],
      "js": [
        "dist/content.js"
      ],
      "run_at": "document_start",
      "all_frames": true,
      "match_about_blank": true,
      "match_origin_as_fallback": true
    }
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+P",
        "mac": "Command+Shift+P"
      },
      "description": "Open PilPod tab navigator"
    }
  }
}