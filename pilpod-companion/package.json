{
  "name": "pilpod-companion",
  "version": "1.3.0",
  "private": true,
  "description": "PilPod browser companion extension (MV3)",
  "type": "module",
  "scripts": {
    "build": "esbuild src/content.js --bundle --outfile=dist/content.js --format=iife --platform=browser --target=chrome109",
    "package": "npm run build && node scripts/package.mjs",
    "lint": "eslint src",
    "test": "vitest run"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "esbuild": "^0.27.7",
    "eslint": "^9.28.0",
    "globals": "^16.2.0",
    "vitest": "^3.2.4"
  }
}
